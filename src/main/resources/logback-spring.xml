<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <springProperty
            scope="context"
            name="LOG_LEVEL"
            source="LOG_LEVEL"
            defaultValue="INFO"/>

    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                %green(%d{yyyy-MM-dd HH:mm:ss.SSS})
                %blue(%-5level)
                %red([%thread])
                %yellow(traceId=%X{traceId})
                %cyan(%logger{25})
                - %msg%n
            </pattern>
        </encoder>

    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>